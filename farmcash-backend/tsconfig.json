{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@farmcash/shared": ["modules/shared/src"],
      "@farmcash/shared/*": ["modules/shared/src/*"],
      "@farmcash/database": ["modules/database/src"],
      "@farmcash/database/*": ["modules/database/src/*"],
      "@farmcash/auth": ["modules/auth/src"],
      "@farmcash/auth/*": ["modules/auth/src/*"],
      "@farmcash/marketplace": ["modules/marketplace/src"],
      "@farmcash/marketplace/*": ["modules/marketplace/src/*"],
      "@farmcash/negotiation": ["modules/negotiation/src"],
      "@farmcash/negotiation/*": ["modules/negotiation/src/*"],
      "@farmcash/orders": ["modules/orders/src"],
      "@farmcash/orders/*": ["modules/orders/src/*"],
      "@farmcash/finance": ["modules/finance/src"],
      "@farmcash/finance/*": ["modules/finance/src/*"],
      "@farmcash/logistics": ["modules/logistics/src"],
      "@farmcash/logistics/*": ["modules/logistics/src/*"],
      "@farmcash/messaging": ["modules/messaging/src"],
      "@farmcash/messaging/*": ["modules/messaging/src/*"],
      "@farmcash/ai": ["modules/ai/src"],
      "@farmcash/ai/*": ["modules/ai/src/*"],
      "@farmcash/notifications": ["modules/notifications/src"],
      "@farmcash/notifications/*": ["modules/notifications/src/*"],
      "@farmcash/oversight": ["modules/oversight/src"],
      "@farmcash/oversight/*": ["modules/oversight/src/*"],
      "@farmcash/cooperatives": ["modules/cooperatives/src"],
      "@farmcash/cooperatives/*": ["modules/cooperatives/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}