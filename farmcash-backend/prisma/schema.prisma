model annonces_vente {
  id                                     String                      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  farmer_id                              String                      @db.Uuid
  produit_id                             String?                     @db.Uuid
  qualite                                product_quality             @default(STANDARD)
  titre                                  String                      @db.VarChar(200)
