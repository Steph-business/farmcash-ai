  /// le farmer à la publication (peut être déjà passée si le produit
  /// est déjà récolté, ou future = pré-vente). Utilisé pour planifier
  /// la livraison et matcher avec les besoins acheteurs.
  date_recolte                           DateTime?                   @db.Date
  status                                 product_status              @default(DRAFT)
  views_count                            Int                         @default(0)
  contacts_count                         Int                         @default(0)
  created_at                             DateTime                    @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime                    @default(now()) @db.Timestamptz(6)
  assigned_to_cooperative_id             String?                     @db.Uuid
  coop_status                            coop_annonce_status?
  coop_publication_id                    String?                     @db.Uuid
  quantite_kg_validee                    Decimal?                    @db.Decimal(10, 2)
  qualite_validee                        product_quality?
  validee_at                             DateTime?                   @db.Timestamptz(6)
  validee_by                             String?                     @db.Uuid
  notes_pesee                            String?
  rejected_reason                        String?
  annonce_vente_traitements              annonce_vente_traitements[]
  cooperative_profiles                   cooperative_profiles?       @relation(fields: [assigned_to_cooperative_id], references: [id], onUpdate: NoAction, map: "annonces_vente_assigned_coop_fkey")
  publications_stock_coop                publications_stock_coop?    @relation(fields: [coop_publication_id], references: [id], onUpdate: NoAction, map: "annonces_vente_coop_publication_fkey")
  users                                  users                       @relation(fields: [farmer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  produits_agricoles                     produits_agricoles?         @relation(fields: [produit_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  regions_ci                             regions_ci?                 @relation(fields: [region_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_annonces_vente_validee_byTousers users?                      @relation("annonces_vente_validee_byTousers", fields: [validee_by], references: [id], onUpdate: NoAction)
  villes_ci                              villes_ci?                  @relation(fields: [ville_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  candidatures_achat                     candidatures_achat[]
  commandes_vente                        commandes_vente[]
  coop_advance_payments                  coop_advance_payments[]
  favoris                                favoris[]
  lot_contributions                      lot_contributions[]
  medias                                 medias[]
  panier_items                           panier_items[]
  previsions_production                  previsions_production[]
  propositions_vente                     propositions_vente[]
  publication_contributions              publication_contributions[]
  stock                                  stock[]
  coop_collections                       coop_collections[]

  @@index([farmer_id], map: "idx_annonces_farmer")
  @@index([location], map: "idx_annonces_location", type: Gist)
  @@index([region_id], map: "idx_annonces_region")
  @@index([ville_id], map: "idx_annonces_ville")
}

