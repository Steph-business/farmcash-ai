// =====================================================================
//  COOP LOGISTICS — Parc véhicules et collectes internes
//  ---------------------------------------------------------------------
//  Parc de véhicules détenu par une coopérative + planification de
//  collectes membre → coop (avant pesée et stockage).
// =====================================================================

model coop_vehicles {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cooperative_id    String              @db.Uuid
  type              String              @db.VarChar(30)
  immatriculation   String?             @unique @db.VarChar(20)
  marque            String?             @db.VarChar(50)
  charge_max_kg     Decimal             @db.Decimal(10, 2)
  chauffeur_nom     String?             @db.VarChar(100)
  chauffeur_phone   String?             @db.VarChar(20)
  is_active         Boolean             @default(true)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  cooperative_profiles cooperative_profiles @relation(fields: [cooperative_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  coop_collections  coop_collections[]

  @@index([cooperative_id], map: "idx_coop_vehicles_coop")
}

model coop_collections {
  id                  String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cooperative_id      String              @db.Uuid
  farmer_id           String              @db.Uuid
  annonce_vente_id    String?             @db.Uuid
  vehicle_id          String?             @db.Uuid
  scheduled_at        DateTime            @db.Timestamptz(6)
  pickup_address      String
  quantite_prevue_kg  Decimal             @db.Decimal(10, 2)
  status              String              @default("PLANNED") @db.VarChar(20)
  notes               String?
  completed_at        DateTime?           @db.Timestamptz(6)
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  updated_at          DateTime            @default(now()) @db.Timestamptz(6)
  cooperative_profiles cooperative_profiles @relation(fields: [cooperative_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               users               @relation("coop_collections_farmerTousers", fields: [farmer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  annonces_vente      annonces_vente?     @relation(fields: [annonce_vente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  coop_vehicles       coop_vehicles?      @relation(fields: [vehicle_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([cooperative_id, status], map: "idx_coop_collections_coop_status")
  @@index([farmer_id], map: "idx_coop_collections_farmer")
  @@index([scheduled_at], map: "idx_coop_collections_scheduled")
}
