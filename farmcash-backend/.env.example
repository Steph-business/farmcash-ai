# =====================================================================
#  FarmCash AI — Variables d'environnement
#  ---------------------------------------------------------------------
#  Copie ce fichier en .env et adapte les valeurs.
#  Pour la prod : ne JAMAIS commiter .env, gérer les secrets via le
#  dashboard Railway/Render et générer des clés via openssl rand -hex 64.
# =====================================================================

# ---------------------------------------------------------------------
#  API
# ---------------------------------------------------------------------
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------
#  Database PostgreSQL + PostGIS
#  (depuis le host Mac : port 5433. Dans Docker network : postgres:5432)
# ---------------------------------------------------------------------
DATABASE_URL="postgresql://farmcash_user:farmcash_pass_2025@localhost:5433/farmcash_db?schema=public"

# ---------------------------------------------------------------------
#  Redis (cache + futurs jobs Bull)
# ---------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=farmcash_redis_2025

# ---------------------------------------------------------------------
#  JWT (auth)
#  JWT_SECRET DOIT faire au moins 32 caractères, sinon refus de boot.
#  Génère un secret prod avec :
#    node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ---------------------------------------------------------------------
JWT_SECRET=replace-with-64-chars-of-random-hex-generated-from-crypto-randomBytes
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------------------------------
#  S3 / MinIO (stockage médias et preuves de livraison)
#  En prod : Cloudflare R2 ou AWS S3.
# ---------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=farmcash_minio
S3_SECRET_KEY=farmcash_minio_2025
S3_BUCKET=farmcash

# Domaines autorisés pour media_url (whitelist messaging anti-phishing).
# CSV. Ajouter ton CDN prod ici.
MEDIA_URL_ALLOWED_DOMAINS=cdn.farmcash.ci,storage.farmcash.ci

# ---------------------------------------------------------------------
#  SMTP (Mailhog en dev, Resend/Brevo en prod)
# ---------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@farmcash.ai

# ---------------------------------------------------------------------
#  Commissions plateforme (% retenu par FarmCash sur chaque transaction)
#  Configurable à chaud, source de vérité = .env.
# ---------------------------------------------------------------------
SERVICE_FEE_PRODUCT=0.03        # 3% sur le seller à la vente
SERVICE_FEE_TRANSPORT=0.03      # 3% sur le transporter à la livraison

# ---------------------------------------------------------------------
#  Réservations sur prévisions (workflow acompte 10%)
# ---------------------------------------------------------------------
RESERVATION_DEPOSIT_RATE=0.10                   # 10% d'acompte au moment de la résa
RESERVATION_FINAL_PAYMENT_DAYS=7                # délai pour payer le solde après conversion
RESERVATION_EXPIRED_DEPOSIT_POLICY=FORFEIT_TO_FARMER  # ou REFUND_BUYER

# Compat historique (utilisé par certains tests E2E)
PREVISION_DOWNPAYMENT_RATE=0.20

# ---------------------------------------------------------------------
#  Payment providers (Mobile Money)
#  En dev : mock (simule délais + webhooks). En prod : cinetpay|orange|mtn|wave.
# ---------------------------------------------------------------------
PAYMENT_PROVIDER=mock

# Taux d'échec simulé par MockPaymentProvider (0–1). 0 = jamais d'échec.
FINANCE_MOCK_FAIL_RATE=0

# CinetPay (sandbox / prod)
# CINETPAY_BASE_URL=https://api-checkout.cinetpay.com/v2
# CINETPAY_API_KEY=
# CINETPAY_SITE_ID=

# Orange Money CI (à brancher avec compte marchand)
# ORANGE_BASE_URL=https://api.orange.com/orange-money-webpay/dev/v1
# ORANGE_CLIENT_ID=
# ORANGE_CLIENT_SECRET=
# ORANGE_MERCHANT_KEY=

# MTN MoMo (sandbox momodeveloper.mtn.com)
# MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com
# MTN_PRIMARY_KEY=
# MTN_SECONDARY_KEY=

# ---------------------------------------------------------------------
#  AI providers (mock en dev, à brancher en prod)
# ---------------------------------------------------------------------
# PLANT_AI_PROVIDER=plant_id
# PLANT_ID_API_KEY=
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-

# ---------------------------------------------------------------------
#  Tests E2E
#  Met à true pendant les tests pour bypasser le rate limit global.
# ---------------------------------------------------------------------
DISABLE_THROTTLE=false

# ---------------------------------------------------------------------
#  Cron jobs en arrière-plan (peuvent être désactivés en tests)
# ---------------------------------------------------------------------
DISABLE_RECONCILIATION_CRON=false     # daily : audit wallets ↔ transactions
DISABLE_ORDERS_CLEANUP=false          # hourly : commandes SENT >24h → CANCELLED
DISABLE_RESERVATION_EXPIRATION=false  # hourly : réservations AWAITING_FINAL expirées
DISABLE_LOGISTICS_CLEANUP=false       # hourly : shipments REQUESTED orphelins >48h

# ---------------------------------------------------------------------
#  Bootstrap admin
#  Token secret pour créer le 1er SUPER_ADMIN via POST /auth/admin/bootstrap.
#  Doit être envoyé dans le header X-Bootstrap-Token. La route refuse si :
#   • le token n'est pas défini ici
#   • le token fourni ne matche pas
#   • un admin existe déjà en base
#  ⚠️ Rotate (ou retire) cette valeur APRÈS la création du 1er admin.
# ---------------------------------------------------------------------
BOOTSTRAP_ADMIN_TOKEN=change-me-once-then-rotate
